rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isEmployer() {
      return getUserRole() == 'employer';
    }
    
    function isEmployee() {
      return getUserRole() == 'employee';
    }
    
    function belongsToSameCompany(companyId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.company_id == companyId;
    }

    // Users collection
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if isAuthenticated() && isOwner(userId);
      
      // Employers can read employees in their company
      allow read: if isAuthenticated() && isEmployer() && 
        belongsToSameCompany(resource.data.company_id);
    }

    // Companies collection
    match /companies/{companyId} {
      // Only employers can read their company data
      allow read: if isAuthenticated() && isEmployer() && 
        belongsToSameCompany(companyId);
      
      // Only employers can create/update their company
      allow write: if isAuthenticated() && isEmployer() && 
        (resource == null || belongsToSameCompany(companyId));
    }

    // Mental health reports collection
    match /mental_health_reports/{reportId} {
      // Employees can only read/write their own reports
      allow read, write: if isAuthenticated() && isEmployee() && 
        isOwner(resource.data.employee_id);
      
      // Employers can read anonymized reports from their company employees
      allow read: if isAuthenticated() && isEmployer() && 
        exists(/databases/$(database)/documents/users/$(resource.data.employee_id)) &&
        belongsToSameCompany(get(/databases/$(database)/documents/users/$(resource.data.employee_id)).data.company_id);
    }

    // Chat sessions collection
    match /chat_sessions/{sessionId} {
      // Employees can only access their own chat sessions
      allow read, write: if isAuthenticated() && isEmployee() && 
        isOwner(resource.data.employee_id);
      
      // Chat messages subcollection
      match /messages/{messageId} {
        // Employees can only access messages in their own sessions
        allow read, write: if isAuthenticated() && isEmployee() && 
          isOwner(get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.employee_id);
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}